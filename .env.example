# Database connection (local development)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASS=yourpassword
DB_NAME=neetcode_practice

# Cloud SQL instance connection name (Cloud Run)
# Format: project:region:instance
# INSTANCE_CONNECTION_NAME=your-project:region:your-instance

# Server port
PORT=3001

# JWT Auth (generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_SECRET=your_64_char_hex_secret_here
JWT_EXPIRES_IN=7d

# Gemini API Key
GEMINI_API_KEY=your_gemini_api_key_here
